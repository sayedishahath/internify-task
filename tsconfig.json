{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "rootDir": ".",
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node"]
  },
  "include": ["index.ts", "config/**/*.ts", "controllers/**/*.ts", "middlewares/**/*.ts", "models/**/*.ts", "routes/**/*.ts", "types/**/*.ts"]
}
